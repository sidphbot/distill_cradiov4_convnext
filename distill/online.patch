+    _, pil_rs, _ = next(iter(train_dl))
+    pv = proc(images=pil_rs, return_tensors="pt", do_resize=False, do_center_crop=False).pixel_values.to(device)
+
+    if device.startswith("cuda"):
+        with torch.amp.autocast("cuda", enabled=teacher_amp):
+            summary, spatial_tokens = teacher(pv)
+    else:
+        summary, spatial_tokens = teacher(pv)
+
+    Ct = int(summary.shape[-1])
+    Tt = int(spatial_tokens.shape[1])
+    Dt = int(spatial_tokens.shape[-1])
+    Ht = size // patch_size
+    Wt = size // patch_size
+    assert Tt == Ht * Wt, f"Teacher token count T={Tt} != {Ht}*{Wt} (check size/patch_size/teacher proc)"
+    return Ct, Dt, Ht, Wt
