+def teacher_forward_fixed(
+        teacher,
+        proc,
+        pil_imgs: list[Image.Image],
+        device: str,
+        *,
+        size: int = 416,
+        amp: bool = True,
+):
+    """
+    Match caching preprocessing:
+      - resize to (size,size) in PIL
+      - processor called with do_resize=False, do_center_crop=False
+      - teacher returns (summary, spatial_tokens) with spatial_tokens shape (B,T,Dt)
+    """
+    pil_rs = [im.resize((size, size), resample=Image.BICUBIC) for im in pil_imgs]
+    pv = proc(
+        images=pil_rs,
+        return_tensors="pt",
+        do_resize=False,
+        do_center_crop=False,
+    ).pixel_values.to(device, non_blocking=True)
+
+    if device.startswith("cuda"):
+        with torch.amp.autocast("cuda", enabled=amp):
+            summary, spatial_tokens = teacher(pv)
+    else:
+        summary, spatial_tokens = teacher(pv)
+
+    return summary, spatial_tokens
+
